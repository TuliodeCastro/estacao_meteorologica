#ifndef CREDENTIALS_H
#define CREDENTIALS_H

// ─────────────────────────────────────────────────────────────────────
// INSTRUÇÕES DE CONFIGURAÇÃO:
// 1. Copie este arquivo e renomeie como: credentials.h
// 2. Substitua os valores XXXXX pelas suas credenciais reais
// 3. NUNCA commit credentials.h (está no .gitignore)
// 4. Este arquivo credentials.h.example serve como documentação
// ─────────────────────────────────────────────────────────────────────

// ─── Wi-Fi (altere para suas credenciais) ─────────────────────────────
#define WIFI_SSID "XXXXXXXXXXXXXXX"      // Nome da rede Wi-Fi
#define WIFI_PASS "XXXXXXXXXXXXXXX"      // Senha da rede Wi-Fi

// ─── Firebase (obtido no Firebase Console) ──────────────────────────
// Para obter estas credenciais:
// 1. Vá em Firebase Console > Seu Projeto > Project Settings
// 2. Copie a URL do Realtime Database
// 3. Copie a API Key gerada
#define FIREBASE_HOST    "https://seu-projeto-default-rtdb.firebaseio.com"
#define FIREBASE_API_KEY "XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

#endif // CREDENTIALS_H
